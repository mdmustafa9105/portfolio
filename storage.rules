rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to all files
      allow read;

      // Allow write access for authenticated users
      allow write: if request.auth != null;

      // TEMPORARY: Allow write access for all users (for testing - remove in production)
      allow write;
    }
  }
}